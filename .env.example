# Environment contract for fixings-service (single source of truth — no fallbacks).
# Local: set these before `python -m service` (thetaservice.bat does it for you).
# Container: set by compose.yml (see `environment:` + `secrets:`).

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=fixings
POSTGRES_USER=fixings_user

# Paths to secret files (NOT the values). Generated locally / on the Pi, never committed.
POSTGRES_PASSWORD_FILE=secrets/db_password         # raw password; shared with the postgres container
THETADATA_CREDS_FILE=secrets/theta_creds.json      # JSON: {"email": "...", "password": "..."}
